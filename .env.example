PORT=3000
FHIR_BASE_URL=http://localhost:8081/fhir
FHIR_USERNAME=
FHIR_PASSWORD=
FHIR_TIMEOUT_MS=15000
FHIR_PATIENT_PATH=/Patient
FHIR_MDM_QUERY_PATH=/$mdm-query-links
# Comma-separated: MATCH, POSSIBLE_MATCH, NO_MATCH; any/* = MATCH+POSSIBLE_MATCH
FHIR_MDM_MATCH_RESULT=MATCH,POSSIBLE_MATCH
FHIR_MDM_POLL_COUNT=6
FHIR_MDM_FIRST_POLL_DELAY_MS=30000
FHIR_MDM_POLL_DELAY_MS=1000
FHIR_MDM_RESOURCE_ID_MODE=id
FHIR_CRUID_SYSTEM=urn:intelehealth:cruid
FHIR_MDM_GOLDEN_ENTERPRISE_ID_SYSTEM=http://hapifhir.io/fhir/NamingSystem/mdm-golden-resource-enterprise-id
FHIR_MPI_IDENTIFIER_TYPE_TEXT=MPI
OPENMRS_ID_SYSTEM=urn:openmrs:patient-uuid
MEDIATOR_BASIC_AUTH_USERNAME=
MEDIATOR_BASIC_AUTH_PASSWORD=
# URL segment before /Patient/:id for PUT, e.g. openmrs-fhir-mdm -> PUT /openmrs-fhir-mdm/Patient/1001. Empty disables the prefixed route (root PUT /Patient/:id only).
MEDIATOR_PATH_PREFIX=openmrs-fhir-mdm
OPENHIM_REGISTER=false
OPENHIM_API_URL=https://localhost:8080
OPENHIM_USERNAME=root@openhim.org
OPENHIM_PASSWORD=password
OPENHIM_MEDIATOR_URN=urn:mediator:openmrs-fhir-mpi
OPENHIM_ROUTER_URL=http://localhost:3000
OPENHIM_TRUST_SELF_SIGNED=true
OPENHIM_HEARTBEAT_MS=10000
